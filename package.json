{
  "name": "hubstore",
  "version": "1.0.0",
  "description": "HubStore Desktop App",
  "main": "dist/main.js",
  "type": "module",

  "scripts": {
    "dev": "npm-run-all -p watch:main watch:ipc dev:preload dev:renderer dev:electron",
    "watch:main": "node scripts/build-main.mjs --watch",
    "watch:ipc": "node scripts/build-ipc.mjs --watch",
    "dev:preload": "node scripts/build-preload.mjs --watch",
    "dev:renderer": "vite --config src/renderer/vite.config.ts",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron dist/main.js",

    "build": "npm run build:renderer && npm run build:main && npm run build:preload && npm run build:ipc",
    "build:renderer": "vite build --config src/renderer/vite.config.ts",
    "build:main": "node scripts/build-main.mjs",
    "build:preload": "node scripts/build-preload.mjs",
    "build:ipc": "node scripts/build-ipc.mjs",

    "dist": "prisma generate && npm run build && electron-builder",
    "create-admin": "node scripts/createAdmin.mjs",
    "postinstall": "prisma generate"
    
  },

  "build": {
    "appId": "com.hubstore.app",
    "productName": "HubStore",

    "directories": {
      "output": "release"
    },

    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],

    "asar": true,

    "asarUnpack": [
      "**/.prisma/**/*",
      "**/@prisma/engines/**/*"
    ],

    "extraResources": [
      {
        "from": "prisma/dev.db",
        "to": "dev.db"
      }
    ],

    "win": {
      "target": "nsis",
      "artifactName": "HubStore-Setup-${version}.exe"
    },

    "npmRebuild": false,

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },

  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  },

  "dependencies": {
    "@prisma/client": "^5.14.0",
    "autoprefixer": "^10.5.0",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.14.0",
    "prisma": "^5.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "zustand": "^5.0.12"
  }
}
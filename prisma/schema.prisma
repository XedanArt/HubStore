generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Franchise {
  id    Int    @id @default(autoincrement())
  name  String
  code  String   // ex: MCD, STB, KFC
  sites Site[]
}

model Site {
  id          Int      @id @default(autoincrement())
  name        String
  phone       String?
  description String?
  franchiseId Int
  franchise   Franchise @relation(fields: [franchiseId], references: [id])
  interventions Intervention[]
}

model Intervention {
  id            Int      @id @default(autoincrement())
  ticketNumber  Int
  ticketCode    String
  title         String
  description   String?
  date          DateTime
  resolvedAt    DateTime?
  siteId        Int
  site          Site     @relation(fields: [siteId], references: [id])
}
